# --- Neo4j (relationship graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Postgres (users, uploads, job status) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cartographer

# --- Object storage (raw PDFs) ---
# Defaults below point at the local MinIO container in infra/docker-compose.yml.
# Swap for real S3/R2 credentials + endpoint in staging/prod.
S3_BUCKET=cartographer-papers
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# --- LLM / embeddings ---
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# --- Extraction service ---
EXTRACTION_SERVICE_URL=http://localhost:8000
